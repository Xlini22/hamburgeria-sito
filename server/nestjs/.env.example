APP_NAME=bourmet-api
PORT=3000
APP_HOST_PORT=3000

# NestJS running on the host and MySQL exposed by Docker.
DB_HOST=127.0.0.1
DB_PORT=3320
DB_HOST_PORT=3320
DB_NAME=hamburgeria
DB_USER=bourmet_app
DB_PASSWORD=replace-with-a-generated-password
DB_POOL_SIZE=10

# Used only by the MySQL container and never by the NestJS application.
DB_ROOT_PASSWORD=replace-with-a-different-generated-password
# Docker Compose currently reads this compatibility name.
DB_ROOT=replace-with-a-different-generated-password

# Use two different random values of at least 64 characters.
JWT_SECRET=replace-with-a-random-secret-of-at-least-64-characters
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-of-at-least-64-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# false only for local HTTP development; use true behind production HTTPS.
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Used only when the users table is empty.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-temporary-password

# Logs remain in the active table for this many days, then move to the archive.
BOURMET_AUDIT_RETENTION_DAYS=365
